{
  "name": "mfront-core",
  "version": "0.0.2-alpha.11",
  "description": "mFront all core shared logic and services",
  "scripts": {
    "build": "tsdown",
    "version:alpha": "pnpm version prerelease --preid alpha --no-git-tag-version",
    "version:beta": "pnpm version prerelease --preid beta --no-git-tag-version",
    "version:release": "pnpm version patch --no-git-tag-version",
    "publish:alpha": "pnpm publish --tag alpha --no-git-checks",
    "publish:beta": "pnpm publish --tag beta --no-git-checks",
    "publish:release": "pnpm publish --tag latest --no-git-checks",
    "release:alpha": "pnpm run build && pnpm run version:alpha && pnpm run publish:alpha",
    "release:beta": "pnpm run build && pnpm run version:beta && pnpm run publish:beta",
    "release": "pnpm run build && pnpm run version:release && pnpm run publish:release"
  },
  "dependencies": {
    "mmcore": "workspace:*",
    "react-router-dom": "^7.13.0"
  },
  "peerDependencies": {
    "react-dom": "^19.2.4"
  },
  "license": "Apache-2.0",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "author": {
    "name": "Bangla Fighter",
    "url": "https://banglafighter.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/banglafighter/mfront-core"
  },
  "homepage": "https://github.com/banglafighter/mfront-core#readme",
  "bugs": {
    "url": "https://github.com/banglafighter/mfront-core/issues"
  },
  "packageManager": "pnpm@10.28.2",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js",
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "keywords": [
    "mfront-core",
    "mfront",
    "mweb",
    "maintainable",
    "react",
    "frontend",
    "framework",
    "router",
    "mapend"
  ]
}
